# Copy this file to apps/api/.env.local (not committed) and fill in real values.
# Keep this aligned with the runtime env/secrets configured in deploy-qa-api.yml.

NODE_ENV=development
APP_ENV=qa

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173

# Backend Firebase configuration (used by @cottonbro/auth-server)
FIREBASE_PROJECT_ID=cottonbro-dev

# Paste the full JSON for a Firebase service-account credential.
# Example: FIREBASE_ADMIN_JSON={"type":"service_account",...}
FIREBASE_ADMIN_JSON=

TURNSTILE_SECRET=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# In QA deploys this is set to the same value as SMTP_USER.
SMTP_FROM=

PYTHON_SERVICE_URL=
PYTHON_API_KEY=

# Flag used in scripts (set to 1 for local dev runs).
IS_LOCAL_DEV=1
